# ── LLM / AI Providers ───────────────────────────────
# Provider API keys are auto-resolved by naming convention:
#   {PROVIDER_NAME}_API_KEY  (e.g. provider "gemini" -> GEMINI_API_KEY)
# Custom providers can be added in config/model_providers.local.json.
#
# OpenAI (required for default Slow Brain)
OPENAI_API_KEY=your_api_key_here
# Optional: custom base URL for OpenAI-compatible providers
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Alibaba DashScope / Qwen
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Google Gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter (aggregated multi-model gateway)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq
# GROQ_API_KEY=your_groq_api_key_here

# Mistral AI
# MISTRAL_API_KEY=your_mistral_api_key_here

# 智谱 GLM / ZhipuAI
# ZHIPU_API_KEY=your_zhipu_api_key_here

# Moonshot / Kimi
# MOONSHOT_API_KEY=your_moonshot_api_key_here

# SiliconFlow
# SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Local Ollama host (default: http://localhost:11434/v1)
# OLLAMA_HOST=http://localhost:11434/v1

# ── Web Search ───────────────────────────────────────
# BRAVE_API_KEY=your_brave_api_key_here
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ── TTS (Text-to-Speech) ─────────────────────────────
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Perception ───────────────────────────────────────
# Camera device ID (Default: 0)
CAMERA_ID=0

# Screen capture interval in seconds
# CAPTURE_INTERVAL=5

# ── Communication ────────────────────────────────────
# Telegram bot integration
# TELEGRAM_BOT_TOKEN=your_token_here
# Comma-separated Telegram user IDs allowed to interact with the bot
# ALLOWED_USER_IDS=

# Discord bot integration
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Feishu / Lark bot integration
# FEISHU_APP_ID=your_feishu_app_id_here
# FEISHU_APP_SECRET=your_feishu_app_secret_here

# ── Admin Web UI ─────────────────────────────────────
# Port for the admin API server
# ADMIN_API_PORT=8080

# Vite frontend API base (set in web/.env or here)
# VITE_API_BASE=http://localhost:8080

# ── Security / Runtime ───────────────────────────────
# Runtime environment: dev, test, local, production
# GAZER_ENV=dev

# Secret for flow resume tokens (random if omitted; tokens invalid after restart)
# GAZER_FLOW_SECRET=your_random_secret_here

# Flow token TTL in seconds (default: 86400 = 24h)
# GAZER_FLOW_TOKEN_TTL=86400

# ── Hardware ─────────────────────────────────────────
# Serial port override (auto-detected if omitted)
# SERIAL_PORT=COM3

# ── Email ────────────────────────────────────────────
# Email password (Gmail App Password). Prefer this over config file.
# GAZER_EMAIL_PASSWORD=your_app_password_here

# ── Logging ──────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
